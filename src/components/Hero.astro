<section class="hero">
  <div>
    <h1>
      El turismo<br />
      <span class="em">musical</span>
    </h1>
    <p class="hero-sub">Una nueva forma de viajar impulsada por la música.</p>
  </div>
  <div class="hero-meta">
    <div class="hero-meta-row">
      <div class="hero-meta-label">Tema</div>
      <div class="hero-meta-val">El auge de los festivales como motor turístico en España.</div>
    </div>
    <div class="hero-meta-row">
      <div class="hero-meta-label">Firmas</div>
