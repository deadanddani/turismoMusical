---
const base = import.meta.env.BASE_URL;
---

<footer class="colofon">
  <div class="colofon-inner">
    <div class="colofon-title">
      Una nueva forma de <span class="em">viajar</span>.
    </div>
    <ul class="colofon-list">
      <strong>Reportaje</strong>
      <li>Raquel González · Sofía González</li>
      <li>Cristina Mauro · Marta de No Copano</li>
      <li>Kilian Quintana</li>
      <li class="colofon-about">
        <a class="about-link" href={`${base}sobre-nosotros`}>
          <span>Sobre nosotros</span>
          <span class="about-arrow" aria-hidden="true">→</span>
        </a>
      </li>
    </ul>
  </div>
</footer>

<style>
  .colofon-about {
    margin-top: 10px;
    list-style: none;
  }
  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--rule);
    transition: color 0.25s ease, border-color 0.25s ease, gap 0.25s ease;
  }
  .about-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    gap: 12px;
  }
  .about-arrow {
    font-size: 0.85em;
    transition: transform 0.25s ease;
  }
  .about-link:hover .about-arrow { transform: translateX(3px); }
</style>
